# top-most EditorConfig file
root = true

# Default for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# PHP source files follow the WordPress Coding Standards (tabs for indentation).
[*.php]
indent_style = tab
indent_size = 4
max_line_length = 120
insert_final_newline = true

# Tests follow PSR-12 (four-space indent) and are not linted by PHPCS.
[tests/**.php]
indent_style = space
indent_size = 4

# YAML (e.g., PHPStan, ECS)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false

# Shell scripts
[*.sh]
end_of_line = lf